{
  "name": "@hitl-kit/mcp",
  "version": "0.6.0",
  "description": "MCP server for HITL Kit. Exposes the 15 HITL primitive event kinds as MCP tools so Claude Code, Cursor, Claude Desktop, and any MCP-aware client can emit schema-validated human-in-the-loop events.",
  "keywords": [
    "hitl",
    "human-in-the-loop",
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "claude",
    "cursor"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "hitl-kit-mcp": "./dist/bin.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@hitl-kit/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod-to-json-schema": "^3.24.1"
  },
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5",
    "zod": "^3.23.0"
  },
  "license": "MIT",
  "author": "Ieuan King <ieuan@ubik.studio>",
  "homepage": "https://hitlkit.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akaieuan/HITL-KIT.git",
    "directory": "packages/mcp"
  },
  "publishConfig": {
    "access": "public"
  }
}
