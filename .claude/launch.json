{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "HITL Kit (Next.js dev)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3000
    },
    {
      "name": "HITL Kit (production)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["start"],
      "port": 3000
    },
    {
      "name": "demo-langgraph",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "demo-langgraph", "dev"],
      "port": 3100
    }
  ]
}
